<!DOCTYPE html>
<html>
<head>
  <title>GossipSite</title>
  <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag 'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>

<body>
  <!-- Barre de navigation -->
  <nav class="navbar navbar-expand-lg navbar-light bg-light">
    <div class="container">
      <%= link_to "GossipSite", root_path, class: "navbar-brand" %>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <div class="mx-auto">  <!-- Utilisation de 'mx-auto' pour centrer -->
          <ul class="navbar-nav">
            <li class="nav-item me-3">
              <%= link_to "Accueil", root_path, class: "nav-link" %>
            </li>
            <li class="nav-item me-3">
              <%= link_to "Team", team_path, class: "nav-link" %>
            </li>
            <li class="nav-item me-3">
              <%= link_to "Contact", contact_path, class: "nav-link" %>
            </li>
          </ul>
        </div>

        <!-- Espacer le côté droit pour les connexions -->
        <ul class="navbar-nav ms-auto">
          <% if logged_in? %>
            <li class="nav-item">
              <%= button_to "Se déconnecter", logout_path, method: :delete, class: "btn btn-link nav-link" %>
            </li>
          <% else %>
            <li class="nav-item me-3">
              <%= link_to "Se connecter", login_path, class: "nav-link" %>
            </li>
            <li class="nav-item me-3">
              <%= link_to "S'inscrire", new_user_path, class: "nav-link" %>
            </li>
          <% end %>
        </ul>

      </div>
    </div>
  </nav>

  <div class="container">
    <%= yield %>
  </div>

  <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.5.2/dist/umd/popper.min.js"></script>
  <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>
