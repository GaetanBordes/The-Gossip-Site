<div class="container mt-5 blog-container">
  <!-- Titre principal -->
  <h1 class="display-4 font-italic text-center mb-4">Bienvenue sur Gossip Site</h1>

  <!-- Section d'accueil pour l'utilisateur connecté ou non -->
  <div class="text-center mb-5">
    <% if current_user %>
      <p class="lead">Bienvenue <%= current_user.username %> !</p>
      <%= link_to 'Créer un Gossip', new_gossip_path, class: "btn btn-success btn-lg" %>
    <% else %>
      <p class="lead">Merci de vous 
        <%= link_to 'connecter', login_path, class: "btn btn-secondary btn-lg" %> pour créer un gossip.
      </p>
    <% end %>
  </div>

  <!-- Affichage des gossips -->
  <div class="row">
    <% @gossips.each do |gossip| %>
      <div class="col-md-4 mb-4">
        <div class="card shadow-sm h-100 hover-shadow">
          <div class="card-body">
            <h5 class="card-title font-weight-bold"><%= gossip.title %></h5>
            <p class="card-text"><%= truncate(gossip.content, length: 100) %></p>
            <small class="text-muted">
              Posté par <strong><%= gossip.user.username %></strong> le
              <%= gossip.created_at.strftime("%d/%m/%Y") %>
            </small>
            <div class="d-flex justify-content-between align-items-center mt-3">
              <%= link_to 'Lire la suite', gossip_path(gossip), class: "btn btn-primary btn-sm" %>
              <div class="text-right">
                <i class="fas fa-heart text-danger"></i> <%= gossip.likes.count %>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>
