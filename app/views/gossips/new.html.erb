<div class="container mt-5 blog-container">
  <!-- Titre principal -->
  <h1 class="display-4 font-italic text-center mb-4">Créer un nouveau Gossip</h1>

  <%= form_with model: @gossip, local: true do |form| %>
    <!-- Champ Titre -->
    <div class="form-group">
      <%= form.label :title, "Titre", class: "font-weight-bold" %>
      <%= form.text_field :title, class: "form-control", placeholder: "Entrez le titre de votre gossip", required: true %>
      <div class="invalid-feedback">
        Veuillez entrer un titre valide.
      </div>
    </div>

    <!-- Champ Contenu -->
    <div class="form-group">
      <%= form.label :content, "Contenu", class: "font-weight-bold" %>
      <%= form.text_area :content, class: "form-control", rows: 5, placeholder: "Écrivez votre gossip ici...", required: true %>
      <div class="invalid-feedback">
        Veuillez remplir ce champ.
      </div>
    </div>

    <!-- Bouton Soumettre -->
    <div class="form-group text-center">
      <%= form.submit "Créer le Gossip", class: "btn btn-success btn-lg px-5" %>
    </div>
  <% end %>

  <!-- Bouton Retour -->
  <div class="text-center">
    <%= link_to 'Retour aux Gossips', gossips_path, class: "btn btn-secondary btn-lg mt-3" %>
  </div>
</div>
